{
  "name": "open-spec-wb1",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @sprint/frontend",
    "build": "npm run build --workspace @sprint/frontend",
    "lint": "npm run lint --workspace @sprint/frontend",
    "preview": "npm run preview --workspace @sprint/frontend",
    "dev:backend": "npm run dev --workspace @sprint/backend",
    "test:backend": "npm run test --workspace @sprint/backend",
    "test:frontend": "npm run test --workspace @sprint/frontend",
    "test:e2e": "npx playwright test",
    "demo:playwright": "npx playwright test --project=chromium --reporter=list",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@9.0.0"
}
